// version.h.in — CMake configure_file 版本信息模板
// @VAR@ 占位符在构建时由 CMake 替换为实际值
#pragma once

#define HMCL_MAC_BUILDER_VERSION "@PROJECT_VERSION@"           // 版本号（如 1.0.0）
#define HMCL_MAC_BUILDER_VERSION_MAJOR @PROJECT_VERSION_MAJOR@ // 主版本号
#define HMCL_MAC_BUILDER_VERSION_MINOR @PROJECT_VERSION_MINOR@ // 次版本号
#define HMCL_MAC_BUILDER_VERSION_PATCH @PROJECT_VERSION_PATCH@ // 修订号
#define HMCL_MAC_BUILDER_NAME "@HMCL_MAC_BUILDER_NAME@"       // 工具名称
#define HMCL_MAC_BUILDER_REPO "@HMCL_MAC_BUILDER_REPO@"       // 仓库地址
